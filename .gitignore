# 숨김 파일 및 폴더 무시 설정
# =========================================================================
# 파이썬 데이터 분석 프로젝트용 .gitignore
# =========================================================================

# --- 가상환경 및 패키지 관리 (Virtual Environments) ---
.venv/
venv/ 
env/
ENV/
bin/
lib/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Jupyter Notebook 관련 파일 ---
.ipynb_checkpoints
*/.ipynb_checkpoints/*
# IPython
.ipython/
profile_default/
ipython_config.py

# --- 파이썬 컴파일 및 캐시 파일 (Python byte-compiled) ---
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.cache/

# --- 데이터 및 대용량 파일 (Data files) ---
# 데이터 분석용 원본 데이터 및 대용량 파일은 버전에 포함하지 않는 것이 좋습니다.
# 별도의 data/ 폴더를 만들어 데이터를 관리하고 통째로 제외하는 것을 추천합니다.
data/
*.csv
*.xlsx
*.xls
*.tsv
*.parquet
*.pkl
*.pickle
*.h5
*.hd5
*.jsonl
*.db
*.sqlite
*.sqlite3
*.zip
*.tar.gz
*.tgz
*.rar

# --- 환경변수 및 비밀정보 (Environment variables & Secrets) ---
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
secrets.json
credentials.json
*.pem
*.key

# --- IDE 및 운영체제 설정 파일 (IDE & OS files) ---
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/code-workspace

# PyCharm / JetBrains
.idea/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# --- 로그 파일 (Logs) ---
*.log
pip-log.txt
pip-delete-this-directory.txt

# --- 모든 숨김 파일 및 폴더 제외 (점 .으로 시작하는 파일/폴더) ---

# 단, .gitignore 자체는 버전 관리에 포함
!.gitignore
# VS Code 설정 폴더는 위 예외 규칙 처리를 위해 제외하지 않음
!.vscode/
